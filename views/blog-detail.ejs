<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= blog ? blog.title : 'Blog Not Found' %> - BlogBox</title>
  <%- include('partials/signupstyle') %>
  <style>
    /* Main container */
    .container {
      max-width: 900px;
      margin: 20px auto;
      padding: 0 20px;
    }
    
    /* Blog detail styles */
    .blog-detail {
      background: white;
      border-radius: 8px;
      overflow: hidden;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      padding: 30px;
      margin-top: 20px;
    }
    
    .blog-title {
      font-size: 2rem;
      color: #333;
      margin-bottom: 10px;
      line-height: 1.3;
    }
    
    .blog-meta {
      display: flex;
      justify-content: space-between;
      color: #888;
      font-size: 0.9rem;
      margin-bottom: 20px;
      padding-bottom: 15px;
      border-bottom: 1px solid #eee;
    }
    
    .blog-author {
      font-weight: 500;
    }
    
    .blog-content {
      line-height: 1.8;
      color: #444;
      font-size: 1.1rem;
    }
    
    /* Back button */
    .action-links {
      display: flex;
      justify-content: space-between;
      margin: 20px 0;
    }
    
    .back-link {
      color: #0056c8;
      text-decoration: none;
      font-weight: 500;
      display: flex;
      align-items: center;
    }
    
    .back-link:hover {
      text-decoration: underline;
    }
    
    .back-arrow {
      margin-right: 5px;
      font-size: 1.2rem;
    }
    
    .create-blog-btn {
      background: #0056c8;
      color: white;
      border: none;
      padding: 8px 16px;
      border-radius: 4px;
      font-weight: 500;
      cursor: pointer;
      transition: background 0.3s;
      text-decoration: none;
    }
    
    .create-blog-btn:hover {
      background: #0041a1;
    }
    
    /* Not found message */
    .not-found {
      background: white;
      border-radius: 8px;
      padding: 30px;
      text-align: center;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }
    
    .not-found h2 {
      color: #333;
      margin-bottom: 15px;
    }

    /* User welcome style */
    .user-welcome {
      font-weight: 500;
      color: #333;
      margin-right: 15px;
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 20px;
    }
    
    .auth-links {
      display: flex;
      gap: 15px;
    }
  </style>
</head>
<body>
  <nav>
    <div class="nav">
      <div class="logo">
        <img src="/assets/BlogBox logo_light_theme.svg" alt="BlogBox" />
      </div>
      
      <div class="nav-links">
        <!-- User welcome message - hidden by default -->
        <div class="user-welcome" style="display:none;">
          Hi, <span id="user-name"></span>
        </div>
        
        <!-- Auth links -->
        <div class="auth-links">
          <a href="/signin" class="auth-link signin-link">Sign In</a>
          <a href="/signup" class="auth-link signup-link">Sign Up</a>
        </div>
        
        <a href="/new-blog" class="create-blog-btn" style="display:none;">Create New Blog</a>
      </div>
      
      <div class="themechanger">
        <img src="/assets/moon-svgrepo-com.svg" alt="Theme Switch" />
      </div>
    </div>
  </nav>
  
  <main>
    <div class="container">
      <div class="action-links">
        <a href="/" class="back-link"><span class="back-arrow">←</span> Back to Explore</a>
      </div>
      
      <% if (blog) { %>
        <article class="blog-detail">
          <h1 class="blog-title"><%= blog.title %></h1>
          <div class="blog-meta">
            <span class="blog-date">Published on <%= new Date(blog.createdAt).toLocaleDateString('en-US', { 
              year: 'numeric', 
              month: 'long', 
              day: 'numeric' 
            }) %></span>
            <span class="blog-author">
              <% if (blog.author) { %>
                By <%= blog.author.username || 'Unknown' %>
              <% } else { %>
                By Anonymous
              <% } %>
            </span>
          </div>
          
          <div class="blog-content">
            <%= blog.body %>
          </div>
        </article>
      <% } else { %>
        <div class="not-found">
          <h2>Blog not found</h2>
          <p>The blog you're looking for doesn't exist or has been removed.</p>
        </div>
      <% } %>
    </div>
  </main>

  <script>
    // Check authentication status on page load
    document.addEventListener('DOMContentLoaded', () => {
      const token = localStorage.getItem('token');
      const firstName = localStorage.getItem('firstName');
      const authLinks = document.querySelector('.auth-links');
      const createBlogBtn = document.querySelector('.create-blog-btn');
      const userWelcome = document.querySelector('.user-welcome');
      const userName = document.getElementById('user-name');
      
      if (token) {
        // User is logged in
        authLinks.style.display = 'none';
        createBlogBtn.style.display = 'block';
        
        // Show welcome message with user's name
        if (firstName) {
          userName.textContent = firstName;
          userWelcome.style.display = 'block';
        }
      } else {
        // User is not logged in
        authLinks.style.display = 'flex';
        createBlogBtn.style.display = 'none';
        userWelcome.style.display = 'none';
      }
    });

    // Theme switching functionality
    document.querySelector('.themechanger').addEventListener('click', () => {
      document.body.classList.toggle('dark-theme');
    });
  </script>
</body>
</html>