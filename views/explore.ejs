<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Explore Blogs - BlogBox</title>
  <%- include('partials/signupstyle') %>
  <style>
    /* Main container */
    .container {
      max-width: 1200px;
      margin: 20px auto;
      padding: 0 20px;
    }
    
    /* Blog card styles */
    .blogs-container {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 20px;
      margin-top: 30px;
    }
    
    .blog-card {
      background: white;
      border-radius: 8px;
      overflow: hidden;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      transition: transform 0.3s ease;
      height: 100%;
      display: flex;
      flex-direction: column;
    }
    
    .blog-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 5px 15px rgba(0, 0, 0, 0.15);
    }
    
    .blog-content {
      padding: 20px;
      flex-grow: 1;
      display: flex;
      flex-direction: column;
    }
    
    .blog-title {
      font-size: 1.3rem;
      margin-bottom: 10px;
      color: #333;
    }
    
    .blog-description {
      color: #666;
      margin-bottom: 15px;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
      flex-grow: 1;
    }
    
    .blog-meta {
      display: flex;
      justify-content: space-between;
      color: #888;
      font-size: 0.85rem;
      margin-top: 10px;
    }
    
    .read-more {
      display: inline-block;
      margin-top: 15px;
      color: #0056c8;
      text-decoration: none;
      font-weight: 500;
      text-align: right;
    }
    
    .read-more:hover {
      text-decoration: underline;
    }
    
    /* Page title */
    .page-title {
      text-align: center;
      margin: 30px 0;
      font-size: 2.2rem;
      color: #333;
    }
    
    /* No blogs message */
    .no-blogs {
      text-align: center;
      padding: 50px 20px;
      background: white;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      margin: 40px auto;
      max-width: 500px;
    }
    
    .no-blogs p {
      margin-bottom: 20px;
      color: #666;
      font-size: 1.1rem;
    }
    
    /* Header bar with auth links */
    .auth-links {
      display: flex;
      justify-content: flex-end;
      margin: 10px 0;
    }
    
    .auth-links a {
      margin-left: 15px;
      color: #0056c8;
      text-decoration: none;
      font-weight: 500;
    }
    
    .auth-links a:hover {
      text-decoration: underline;
    }

    /* Add these styles to your existing CSS */
    .nav-links {
      display: flex;
      align-items: center;
      gap: 20px;
    }
    
    .auth-links {
      display: flex;
      gap: 15px;
    }
    
    .auth-link {
      color: #0056c8;
      text-decoration: none;
      font-weight: 500;
      transition: color 0.3s;
    }
    
    .auth-link:hover {
      color: #0041a1;
    }
    
    .create-blog-btn {
      background: #0056c8;
      color: white;
      padding: 8px 16px;
      border-radius: 4px;
      text-decoration: none;
      font-weight: 500;
      transition: background 0.3s;
    }
    
    .create-blog-btn:hover {
      background: #0041a1;
    }

    .user-welcome {
      font-weight: 500;
      color: #333;
      margin-right: 15px;
    }
  </style>
</head>
<body>
  <nav>
    <div class="nav">
      <div class="logo">
        <img src="/assets/BlogBox logo_light_theme.svg" alt="BlogBox" />
      </div>
      
      <div class="nav-links">
        <!-- User welcome message - hidden by default -->
        <div class="user-welcome" style="display:none;">
          Hi, <span id="user-name"></span>
        </div>
        
        <!-- Auth links -->
        <div class="auth-links">
          <a href="/signin" class="auth-link signin-link">Sign In</a>
          <a href="/signup" class="auth-link signup-link">Sign Up</a>
        </div>
        
        <a href="/new-blog" class="create-blog-btn" style="display:none;">Create New Blog</a>
      </div>
      
      <div class="themechanger">
        <img src="/assets/moon-svgrepo-com.svg" alt="Theme Switch" />
      </div>
    </div>
  </nav>
  
  <main>
    <div class="container">
      <div class="auth-links">
        <a href="/signin">Sign In</a>
        <a href="/signup">Sign Up</a>
      </div>
      
      <h1 class="page-title">Discover Amazing Blogs</h1>
      
      <% if (locals.error) { %>
        <div class="error-message" style="color: red; text-align: center; margin-bottom: 20px;">
          <%= error %>
        </div>
      <% } %>
      
      <div class="blogs-container">
        <% if (blogs && blogs.length > 0) { %>
          <% blogs.forEach(blog => { %>
            <div class="blog-card">
              <div class="blog-content">
                <h2 class="blog-title"><%= blog.title %></h2>
                <p class="blog-description"><%= blog.description %></p>
                <div class="blog-meta">
                  <span><%= new Date(blog.createdAt).toLocaleDateString() %></span>
                  <% if (blog.author) { %>
                    <span>By <%= blog.author.username || 'Unknown' %></span>
                  <% } else { %>
                    <span>By Anonymous</span>
                  <% } %>
                </div>
                <a href="/blogs/<%= blog._id %>" class="read-more">Read More →</a>
              </div>
            </div>
          <% }); %>
        <% } else { %>
          <div class="no-blogs">
            <p>No blogs found yet. Be the first to create one!</p>
            <a href="/new-blog" class="read-more create-blog-btn">Create Blog</a>
          </div>
        <% } %>
      </div>
    </div>
  </main>

  <script>
    // Check authentication status on page load
    document.addEventListener('DOMContentLoaded', () => {
      const token = localStorage.getItem('token');
      const firstName = localStorage.getItem('firstName');
      const authLinks = document.querySelector('.auth-links');
      const createBlogBtn = document.querySelector('.nav-links .create-blog-btn');
      const userWelcome = document.querySelector('.user-welcome');
      const userName = document.getElementById('user-name');
      
      if (token) {
        // User is logged in
        authLinks.style.display = 'none';
        createBlogBtn.style.display = 'block';
        
        // Show welcome message with user's name
        if (firstName) {
          userName.textContent = firstName;
          userWelcome.style.display = 'block';
        }
      } else {
        // User is not logged in
        authLinks.style.display = 'flex';
        createBlogBtn.style.display = 'none';
        userWelcome.style.display = 'none';
      }
    });

    // Theme switching functionality
    document.querySelector('.themechanger').addEventListener('click', () => {
      document.body.classList.toggle('dark-theme');
    });

    // Check if user is logged in before creating blogs
    document.querySelectorAll('.create-blog-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const token = localStorage.getItem('token');
        if (!token) {
          e.preventDefault();
          alert('Please log in to create blogs');
          window.location.href = '/signin';
        }
      });
    });
  </script>
</body>
</html>