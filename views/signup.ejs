<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        @import url("https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap");
        font-family: "Poppins";
        background-color: #f5f5f5;
      }
       .nav {
        padding: 0 1vw;
        width: 100vw;
        height: 10vh;
        display: flex;
        justify-content: space-between;
        align-items: center;
        overflow: hidden;
        background-color: #efefef;
      }
      .logo {
        flex: 1;
        display: flex;
        justify-content: center;
        align-items: center;
      }
      .logo img {
        height: 9vh;
        width: auto;
      }
      .themechanger {
        display: flex;
        justify-content: center;
        align-items: flex-end;
      }
      .themechanger img {
        height: 6vh;
        width: auto;
      } 
      
      /* form styling  */
      
      /* Container Styles */
      .container {
        max-width: 400px;
        margin: 40px auto;
        padding: 20px;
        background: #fff;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      }

      /* Heading */
      h2 {
        text-align: center;
        margin-bottom: 20px;
      }

      /* Input Fields */
      input {
        width: 100%;
        padding: 10px;
        margin: 10px 0;
        border: 1px solid #ccc;
        border-radius: 4px;
      }
      
      /* Button */
      button {
        width: 100%;
        padding: 10px;
        background: #0056c8; /* Your chosen blue color */
        color: #fff;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-size: 16px;
      }
      button:hover {
        background: #0041a1;
      }
      
      /* Link Section */
      .link {
        text-align: center;
        margin-top: 10px;
      }
      .link a {
        color: #0056c8;
        text-decoration: none;
      }
      .link a:hover {
        text-decoration: underline;
      }

      /* Feedback Message */
      #message {
        text-align: center;
        margin-top: 10px;
        font-weight: bold;
      }
      
      /* Responsive Adjustments */
      @media (max-width: 500px) {
        .container {
          margin: 20px;
          padding: 15px;
        }
      }
      </style>
  </head>
  <body>
    <nav>
      <div class="nav">
        <div class="logo">
          <img src="../assets/BlogBox logo_light_theme.svg" alt="" />
        </div>
        <div class="themechanger">
          <img src="../assets/moon-svgrepo-com.svg" alt="" />
        </div>
      </div>
    </nav>
    <main>
      <div class="container">
        <h2>Create an Account</h2>
        <form id="signupForm">
          <input type="text" id="firstname" placeholder="First Name" required />
          <input type="text" id="lastname" placeholder="Last Name" required />
          <input type="email" id="email" placeholder="Email" required />
          <input type="text" id="username" placeholder="Username" required />
          <input
            type="password"
            id="password"
            placeholder="Password"
            required
          />
          <button type="submit">Sign Up</button>
        </form>
        <div class="link">
          Already a user? <a href="signin">Sign In</a>
        </div>
        <div id="message"></div>
      </div>
    </main>

    <script>
      //handle form submission
      document
        .getElementById("signupForm")
        .addEventListener("submit", async (e) => {
          e.preventDefault();

          //gather form values
          const firstname = document.getElementById("firstname").value;
          const lastname = document.getElementById("lastname").value;
          const email = document.getElementById("email").value;
          const username = document.getElementById("username").value;
          const password = document.getElementById("password").value;

          try {
            //send POST request to server
            const res = await fetch('http://localhost:3000/auth/signup', {
              method: "POST",
              headers: {
                "Content-Type": "application/json",
              },
              body: JSON.stringify({
                firstname,
                lastname,
                email,
                username,
                password,
              }),
            });
            const data = await res.json();

            //Update message text&color based on sucess or error
            const messageElem = document.getElementById("message");
            if (res.ok) {
              messageElem.style.color = "green";
              messageElem.innerText = data.message || "Signup successful!";
            } else {
              messageElem.style.color = "red";
              messageElem.innerText = data.message || "Signup failed!";
            }
          } catch (error) {
            document.getElementById("message").style.color = "red";
            document.getElementById("message").innerText =
              "Error: this is " + error.message;
          }
        });
    </script>
  </body>
</html>
